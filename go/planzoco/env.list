# This is a .env file that contains SAFE values, not secrets
# DATABASE_URL is required and is not set here since it contains credentials.
# In-cluster it is sourced from the CloudNativePG-generated Secret's `uri` key.
# For local development, set it yourself, e.g.:
#   DATABASE_URL=postgres://planzoco:planzoco@localhost:5432/planzoco?sslmode=disable
